# Copy to .env to override. All values have sane defaults in src/config.js,
# so the app runs with no .env at all.

PORT=3000

# Primary store
DB_PATH=data/typeahead.db

# Suggestions
SUGGEST_LIMIT=10

# Ranking: "popularity" (all-time count) or "trending" (recency-aware)
RANK_MODE=trending

# Distributed cache
CACHE_NODES=3            # number of logical cache nodes
CACHE_VNODES=150         # virtual nodes per physical node on the hash ring
CACHE_TTL_MS=30000       # suggestion entry lifetime

# Recency / trending
TRENDING_HALF_LIFE_MS=600000   # 10 min: how fast recent activity decays
TRENDING_WEIGHT=3              # how strongly recent activity boosts ranking

# Batch writer
FLUSH_MS=2000            # flush interval
FLUSH_SIZE=500           # flush early once this many distinct queries are buffered
